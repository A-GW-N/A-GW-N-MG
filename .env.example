# Supabase public schema 配置
SUPABASE_URL=https://your-project.supabase.co
# Supabase 匿名访问 Key
SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-public-or-anon-key
# Service Role Key（服务端使用，绕过 RLS，切勿暴露到客户端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_PASSWORD=change-me
APP_BASE_URL=https://your-public-domain.example.com
LINUXDO_OAUTH_CLIENT_ID=your-linuxdo-client-id
LINUXDO_OAUTH_CLIENT_SECRET=your-linuxdo-client-secret
LINUXDO_OAUTH_CALLBACK_URL=http://localhost:3000/api/user/oauth/linuxdo/callback
# 可选：如需要再显式填写，例如 profile / user；留空时默认不附带 scope
LINUXDO_OAUTH_SCOPE=
# 可选：浏览器授权默认 connect.linux.do；服务端 token / userinfo 默认 connect.linuxdo.org
LINUXDO_OAUTH_AUTHORIZATION_URL=
LINUXDO_OAUTH_TOKEN_URL=
LINUXDO_OAUTH_USERINFO_URL=
GATEWAY_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret
# 可选：环境变量回退网关 key。正式建议在 /admin/management 里创建数据库密钥
GATEWAY_API_KEYS=sk-change-me
GO_PROXY_BASE_URL=http://127.0.0.1:8081
GO_PROXY_HOST=0.0.0.0
GO_PROXY_PORT=8081

# 可选：自定义数据库 schema，默认 public
SUPABASE_DB_SCHEMA=public
# 轮询间隔（秒）
CHECK_POLL_INTERVAL_SECONDS=60
# 节点身份（多节点部署时标识实例）
CHECK_NODE_ID=local
# 历史数据保留天数（范围 7-365）
HISTORY_RETENTION_DAYS=30
# 官方状态检查间隔
OFFICIAL_STATUS_CHECK_INTERVAL_SECONDS=60
# 最大请求并发数
CHECK_CONCURRENCY=8
